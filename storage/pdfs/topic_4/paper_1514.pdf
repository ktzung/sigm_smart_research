    <title>Tri-branch feature pyramid network based on federated particle swarm optimization for polyp segmentation</title>
	    <meta name="_sowise_journalid" content="10001"/>
	<meta name="WT.cg_n" content="Mathematical Biosciences and Engineering"/>
