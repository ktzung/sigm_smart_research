			                    			                    				                    		<li><a class="underHigh mainColor" href="javascript:void(0);" data="artificial intelligence" type="keywords.keywordEn">artificial intelligence</a>, 			                    		</li>
			                    				                    			                    				                    		<li><a class="underHigh mainColor" href="javascript:void(0);" data="deep learning" type="keywords.keywordEn">deep learning</a>, 			                    		</li>
			                    				                    			                    				                    		<li><a class="underHigh mainColor" href="javascript:void(0);" data="federated learning" type="keywords.keywordEn">federated learning</a>, 			                    		</li>
			                    				                    			                    				                    		<li><a class="underHigh mainColor" href="javascript:void(0);" data="colon polyps segmentation" type="keywords.keywordEn">colon polyps segmentation</a>, 			                    		</li>
			                    				                    			                    				                    		<li><a class="underHigh mainColor" href="javascript:void(0);" data="multi-branch network" type="keywords.keywordEn">multi-branch network</a>			                    		</li>
			                    				                    		                    </ul>
	                    	                    
	                    <p class="citation-p"><b class="subtit-b">Citation:</b> 										Kefeng Fan, Cun Xu, Xuguang Cao, Kaijie Jiao, Wei Mo. Tri-branch feature pyramid network based on federated particle swarm optimization for polyp segmentation[J]. <i>Mathematical Biosciences and Engineering</i>, 2024, 21(1): 1610-1624. <span style="display:inline-block;">doi: <a class="mainColor" href="https://doi.org/10.3934/mbe.2024070" target="_blank" class="mainColor">10.3934/mbe.2024070</a></span>								</p>
	                    
