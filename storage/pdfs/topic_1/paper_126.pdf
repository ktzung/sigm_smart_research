	xplGlobal.document.metadata={"userInfo":{"institute":false,"member":false,"individual":false,"guest":false,"subscribedContent":false,"fileCabinetContent":false,"fileCabinetUser":false,"dtrDeleteCookieOnLogout":false,"institutionalFileCabinetUser":false,"dtrCookieExpirationDays":0,"showPatentCitations":true,"showGet802Link":false,"showOpenUrlLink":false,"tracked":false,"institutionUserId":0,"delegatedAdmin":false,"desktop":false,"isInstitutionDashboardEnabled":false,"isInstitutionProfileEnabled":false,"isRoamingEnabled":false,"isDelegatedAdmin":false,"isMdl":false,"isCwg":false,"isAcademic":false,"isIel":false,"isReadAndPublish":false},"authors":[{"name":"Chiara Lanza","affiliation":["Centre Tecnològic de Telecomunicacions de Catalunya (CTTC/CERCA), Barcelona, Spain","Department of Signal Theory and Communications (TSC), Universitat Politècnica de Catalunya (UPC), Barcelona, Spain"],"bio":{"graphic":"/mediastore/IEEE/content/freeimages/6287639/10820123/10945356/lanza-3555750-small.gif","p":["Chiara Lanza received the B.Sc. degree in management engineering and the M.Sc. degree in ICT for smart societies from the Politecnico di Torino, in 2019 and 2021, respectively. She is currently pursuing the Ph.D. degree with the Signal Theory and Communications Department, Technical University of Catalonia. In January 2022, she joined the Sustainable AI Research Unit, Centre Tecnologic de Telecomunicacions de Catalunya (CTTC). She was part of the GREENEDGE (MSCA-ETN) Project. Her research focuses on distributed, decentralized, and sustainable machine learning algorithms."]},"firstName":"Chiara","lastName":"Lanza","orcid":"0000-0002-7026-7080","id":"37089797712"},{"name":"Tinne Tuytelaars","affiliation":["ESAT-PSI, KU Leuven, Leuven, Belgium"],"bio":{"graphic":"/mediastore/IEEE/content/freeimages/6287639/10820123/10945356/tuyte-3555750-small.gif","p":["Tinne Tuytelaars (Member, IEEE) received the M.Sc. and Ph.D. degrees from KU Leuven, in 1996 and 2000, respectively. Currently, she is a Full Professor with KU Leuven, where she teaches and performs research in computer vision and machine learning, with a special interest for continual learning, representation learning, and multimodal learning. She received the ERC Starting Grant, in 2009; the ERC Advanced Grant, in 2021; and the Koenderink Test-Of-Time Award at ECCV16. She has been the Program Chair of ECCV14 and CVPR21 and the General Chair of CVPR16."]},"firstName":"Tinne","lastName":"Tuytelaars","orcid":"0000-0003-3307-9723","id":"37282935100"},{"name":"Marco Miozzo","affiliation":["Centre Tecnològic de Telecomunicacions de Catalunya (CTTC/CERCA), Barcelona, Spain"],"bio":{"graphic":"/mediastore/IEEE/content/freeimages/6287639/10820123/10945356/miozz-3555750-small.gif","p":["Marco Miozzo received the M.Sc. degree in telecommunication engineering from the University of Ferrara, Italy, in 2005, and the Ph.D. degree from the Technical University of Catalonia (UPC), in 2018. In June 2008, he joined the Centre Tecnologic de Telecomunicacions de Catalunya (CTTC). His main research interests include sustainable mobile networks, green wireless networking, multi-agent systems, machine learning, green AI, distributed and collaborative learning, and pervasive AI."]},"firstName":"Marco","lastName":"Miozzo","orcid":"0000-0003-3872-5907","id":"37299928500"},{"name":"Eduard Angelats","affiliation":["Centre Tecnològic de Telecomunicacions de Catalunya (CTTC/CERCA), Barcelona, Spain"],"bio":{"graphic":"/mediastore/IEEE/content/freeimages/6287639/10820123/10945356/angel-3555750-small.gif","p":["Eduard Angelats received the M.Sc. and Ph.D. degrees in telecommunications engineering from the Technical University of Catalonia (UPC), in 2008 and 2023, respectively. In 2009, he joined the former Institute of Geomatics. Since January 2014, he has been with CTTC, where he is currently a Researcher with the Geomatics Research Unit. His main research interests include satellite remote sensing for coastal monitoring and other applications and the use of AI techniques for understanding geospatial data."]},"firstName":"Eduard","lastName":"Angelats","orcid":"0000-0001-7321-4825","id":"37086581278"},{"name":"Paolo Dini","affiliation":["Centre Tecnològic de Telecomunicacions de Catalunya (CTTC/CERCA), Barcelona, Spain"],"bio":{"graphic":"/mediastore/IEEE/content/freeimages/6287639/10820123/10945356/dini-3555750-small.gif","p":["Paolo Dini received the M.Sc. and Ph.D. degrees from the University of Roma La Sapienza, in 2001 and 2005, respectively. He is currently a Leading Researcher with the Centre Tecnologic de Telecomunicacions de Catalunya (CTTC) and coordinates the activities of the Sustainable AI Research Unit. He has been involved in more than 20 research and development projects. He is currently the Coordinator of CHIST-ERA SONATA Project on sustainable computing and communication at the edge and the Scientific Coordinator of the EU H2020 MSCA Greenedge European Training Network on edge intelligence and sustainable computing. His current research interests include sustainable computing for cyber-physical systems, distributed optimization and optimal control, machine learning, and multi-agent systems. He received two awards from the Cisco Silicon Valley Foundation for his research on distributed control over heterogeneous mobile networks, in 2008 and 2011, respectively. Since 2022, he has been an EU Climate Pact Ambassador."]},"firstName":"Paolo","lastName":"Dini","orcid":"0000-0001-6756-0289","id":"37268502600"}],"issn":[{"format":"Electronic ISSN","value":"2169-3536"}],"articleNumber":"10945356","mediaPath":"/mediastore/IEEE/content/media/6287639/10820123/10945356","dbTime":"1 ms","metrics":{"wosCitationCount":0,"citationCountPaper":2,"citationCountPatent":0,"totalDownloads":643},"purchaseOptions":{"showOtherFormatPricingTab":false,"showPdfFormatPricingTab":true,"pdfPricingInfoAvailable":false,"otherPricingInfoAvailable":false,"mandatoryBundle":false,"optionalBundle":false,"displayTextWhenPdfPricingNotAvailable":"The purchase and pricing options for this item are unavailable. Select items are only available as part of a subscription package. You may try again later or <a href='https://ieeexplore.ieee.org/xpl/contact' target='_blank'>contact us</a> for more information.","displayTextWhenOtherFormatPricingNotAvailable":"The purchase and pricing options for this item are unavailable. Select items are only available as part of a subscription package. You may try again later or <a href='https://ieeexplore.ieee.org/xpl/contact' target='_blank'>contact us</a> for more information."},"getProgramTermsAccepted":false,"sections":{"abstract":"true","authors":"true","disclaimer":"false","figures":"true","multimedia":"false","references":"true","citedby":"true","keywords":"true","definitions":"false","algorithm":"false","dataset":"false","cadmore":"false","footnotes":"true","relatedContent":"false","metrics":"true"},"graphicalAbstract":{"summary":"We propose a decentralised federated approach based on continual learning. In our solution, we adopt knowledge distillation (KD) to share the knowledge from the local models and to incrementally generate a global model at every node visit. Our solution preserves privacy, and avoids centralization bottlenecks and catastrophic forgetting. Here, a diagram of our continual learning approach focusing on a step for a generic node.","type":"graphic","fileSize":"28KB","file":"/ielx8/6287639/10820123/10945356/graphical_abstract/access-gagraphic-3555750.jpg","coverImage":"/ielx8/6287639/10820123/10945356/graphical_abstract/access-gagraphic-3555750.jpg"},"abstract":"Continual learning (CL) is attracting attention to learn in dynamic and non-stationary environments, typical of many real applications, such as those related to Internet of things (IoT). So far, learning in IoT scenarios has almost exclusively been studied in a centralized fashion, but CL can be used in decentralized settings involving a multitude of nodes to learn, adapt, and generalize from their streams of data, even with limited communication and computation capabilities. In this work, we formulate a joint Class and Domain Continual Learning problem, where local data at the nodes might include multiple classes belonging to different domains. In our solution, we adopt knowledge distillation (KD) to share knowledge extracted from local models trained with the data at each node and to incrementally generate a global model, while preserving privacy and avoiding centralization bottlenecks. Thanks to KD, the learning process can be performed without any prior information about the model architecture, i.e., every local model can be based on different architectures, which can also differ from the global. The learning process is also agnostic to domain and classes’ distribution across the nodes. With these features, our distributed learning solution may assist in privacy preservation and save communication resources, which are fundamental challenges in IoT scenarios. Compared against two baseline losses based on state-of-the-art CL solutions and using different datasets (MNIST, USPS, DomainNet), our proposal outperforms different baselines in terms of accuracy, spanning from a gain of 15.9%, up to 95.4%, by limiting catastrophic forgetting.","publicationYear":"2025","publicationDate":"2025","pdfPath":"/iel8/6287639/10820123/10945356.pdf","endPage":"56993","formulaStrippedArticleTitle":"Joint Class and Domain Continual Learning for Decentralized Federated Processes","publicationTitle":"IEEE Access","displayPublicationTitle":"IEEE Access","pdfUrl":"/stamp/stamp.jsp?tp=&arnumber=10945356","startPage":"56982","keywords":[{"type":"IEEE Keywords","kwd":["Peer-to-peer computing","Data models","Internet of Things","Distance learning","Computer aided instruction","Proposals","Federated learning","Continuing education","Computational modeling","Computer architecture"]},{"type":"Index Terms","kwd":["Incremental Learning","Joint Domain","Joint Class","Local Data","Global Model","Prior Information","Internet Of Things","Model Architecture","Computational Capabilities","Privacy Preservation","Catastrophic Forgetting","Internet Of Things Scenarios","Non-stationary Environments","Loss Function","Accuracy Of Model","Machine Learning Models","Test Accuracy","Cross-entropy Loss","Training Loss","End Of Training","Stochastic Gradient Descent Optimizer","Internet Of Things Applications","Auxiliary Dataset","Sequence Learning","Fashion-MNIST","Handwritten Digits","Domain In Order","Auxiliary Data","Zero-knowledge Proof","Communication Overhead"]},{"type":"Author Keywords","kwd":["Class incremental","continual learning","decentralized learning","distributed learning","domain incremental","federated learning","knowledge distillation"]}],"allowComments":true,"authorNames":"Chiara Lanza;Tinne Tuytelaars;Marco Miozzo;Eduard Angelats;Paolo Dini","issueLink":"/xpl/tocresult.jsp?isnumber=10820123&punumber=6287639","pubLink":"/xpl/RecentIssue.jsp?punumber=6287639","displayPublicationDate":"28 March 2025","dateOfInsertion":"28 March 2025","doiLink":"https://doi.org/10.1109/ACCESS.2025.3555750","isGetAddressInfoCaptured":false,"isMarketingOptIn":false,"pubTopics":[{"name":"Aerospace"},{"name":"Bioengineering"},{"name":"Communication, Networking and Broadcast Technologies"},{"name":"Components, Circuits, Devices and Systems"},{"name":"Computing and Processing"},{"name":"Engineered Materials, Dielectrics and Plasmas"},{"name":"Engineering Profession"},{"name":"Fields, Waves and Electromagnetics"},{"name":"General Topics for Engineers"},{"name":"Geoscience"},{"name":"Nuclear Engineering"},{"name":"Photonics and Electrooptics"},{"name":"Power, Energy and Industry Applications"},{"name":"Robotics and Control Systems"},{"name":"Signal Processing and Analysis"},{"name":"Transportation"}],"publisher":"IEEE","displayDocTitle":"Joint Class and Domain Continual Learning for Decentralized Federated Processes","isOpenAccess":true,"isEphemera":false,"isConference":false,"isJournal":true,"isPromo":false,"isDynamicHtml":true,"isTutorial":false,"isSpringer":false,"isChapter":false,"isEarlyAccess":false,"isProduct":false,"isStandard":false,"xploreDocumentType":"Journals & Magazine","isBookWithoutChapters":false,"volume":"13","isBook":false,"isFreeDocument":true,"isOnlineOnly":false,"isLatestStandard":false,"isDegruyter":false,"isCustomDenial":false,"isTranslation":false,"isGiveaway":false,"isOUP":false,"htmlLink":"/document/10945356/","htmlAbstractLink":"/document/10945356/","hasStandardVersions":false,"isSMPTE":false,"isSAE":false,"isNow":false,"persistentLink":"https://ieeexplore.ieee.org/servlet/opac?punumber=6287639","startPage":"56982","fundingAgencies":{"fundingAgency":[{"fundingName":"Spanish Project through Ministerio de Ciencia, Innovación y Universidades (MCIN)/Agencia Estatal de Investigación (AEI)/10.13039/50110001103","grantNumber":"PID2020-113832RB-C22(ORIGIN)"},{"fundingName":"European Union Horizon 2020 Research and Innovation Program through PCI2021-122043-2A/AEI/10.13039/501100011033","grantNumber":"953775 (GREENEDGE) and CHIST-ERA-20-SICT-004 (SONATA)"}]},"subjectCategories":["Computational and artificial intelligence","Computers and information processing"],"openAccessFlag":"T","insertDate":"28 March 2025","ephemeraFlag":"false","title":"Joint Class and Domain Continual Learning for Decentralized Federated Processes","html_flag":"false","ml_html_flag":"true","sourcePdf":"access-lanza-3555750-x.pdf","displayPublicationDate":"28 March 2025","mlTime":"PT0.069943S","xplore-pub-id":"6287639","pdfPath":"/iel8/6287639/10820123/10945356.pdf","isNumber":"10820123","contentType":"periodicals","publicationDate":"2025","publicationNumber":"6287639","citationCount":"2","xplore-issue":"10820123","articleId":"10945356","publicationTitle":"IEEE Access","sections":{"abstract":"true","authors":"true","disclaimer":"false","figures":"true","multimedia":"false","references":"true","citedby":"true","keywords":"true","definitions":"false","algorithm":"false","dataset":"false","cadmore":"false","footnotes":"true","relatedContent":"false","metrics":"true"},"volume":"13","contentTypeDisplay":"Journals","referenceCount":53,"publicationYear":"2025","subType":"IEEE Journal","_value":"CCBY","lastupdate":"2026-03-28","mediaPath":"/mediastore/IEEE/content/media/6287639/10820123/10945356","endPage":"56993","displayPublicationTitle":"IEEE Access","doi":"10.1109/ACCESS.2025.3555750"};








