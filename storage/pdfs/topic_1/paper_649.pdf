                    <h1 class="c-article-title" data-test="article-title" data-article-title="">Secure, privacy-preserving and federated machine learning in medical imaging</h1>
                    <ul class="c-article-author-list c-article-author-list--short" data-test="authors-list" data-component-authors-activator="authors-list"><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="1_4" data-track-context="researcher popup with no profile" href="#auth-Georgios_A_-Kaissis-Aff1-Aff2-Aff3" data-author-popup="auth-Georgios_A_-Kaissis-Aff1-Aff2-Aff3" data-author-search="Kaissis, Georgios A.">Georgios A. Kaissis</a><sup class="u-js-hide"><a href="#Aff1">1</a>,<a href="#Aff2">2</a>,<a href="#Aff3">3</a></sup>, </li><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="2_4" data-track-context="researcher popup with no profile" href="#auth-Marcus_R_-Makowski-Aff1" data-author-popup="auth-Marcus_R_-Makowski-Aff1" data-author-search="Makowski, Marcus R.">Marcus R. Makowski</a><sup class="u-js-hide"><a href="#Aff1">1</a></sup>, </li><li class="c-article-author-list__item c-article-author-list__item--hide-small-screen"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="3_4" data-track-context="researcher popup with no profile" href="#auth-Daniel-R_ckert-Aff2" data-author-popup="auth-Daniel-R_ckert-Aff2" data-author-search="Rückert, Daniel">Daniel Rückert</a><span class="u-js-hide"> 
            <a class="js-orcid" href="https://orcid.org/0000-0002-5683-5889"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0002-5683-5889</a></span><sup class="u-js-hide"><a href="#Aff2">2</a></sup> &amp; </li><li class="c-article-author-list__show-more" aria-label="Show all 4 authors for this article" title="Show all 4 authors for this article">…</li><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="4_4" data-track-context="researcher popup with no profile" href="#auth-Rickmer_F_-Braren-Aff1" data-author-popup="auth-Rickmer_F_-Braren-Aff1" data-author-search="Braren, Rickmer F." data-corresp-id="c1">Rickmer F. Braren<svg width="16" height="16" focusable="false" role="img" aria-hidden="true" class="u-icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-eds-i-mail-medium"></use></svg></a><span class="u-js-hide"> 
