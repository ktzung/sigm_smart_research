        overflow: visible;
        cursor: pointer;
        background: 0 0;
        border: 0;
        -webkit-appearance: none;
        display: block;
        outline: 0;
        padding: 0;
        z-index: 1046;
        -webkit-box-shadow: none;
        box-shadow: none;
        width: 44px;
        height: 44px;
        line-height: 44px;
        position: absolute;
        right: 0px;
        top: 10px;
        text-decoration: none;
        text-align: center;
        opacity: .65;

        font-style: normal;
        font-size: 28px;
    }
        
    @media only screen and (max-width:992px){	
