# ═══════════════════════════════════════════════════════════════
#  LLM Provider
#  Options: openai | perplexity | anthropic | gemini | ollama | openai_compat
#  The chosen provider is used for ALL stages unless overridden per-topic.
#  Note: perplexity is only used for "search" category stages even when set here.
# ═══════════════════════════════════════════════════════════════
LLM_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-kg8lrGTk_UN19onijn3QvljT3BlbkFJm9M42eBBTiK134RlvT_3zEeg37ifvepgvjnSbhDNvdOiVBdLyO3XZ9GLzg53fht5WfbP1RcBAA
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── Perplexity ───────────────────────────────────────────────────
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar-pro

# ── Google Gemini ────────────────────────────────────────────────
# Valid model IDs: gemini-2.0-flash | gemini-2.5-flash-preview-05-20 | gemini-2.5-pro-preview-06-05
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic Claude ─────────────────────────────────────────────
# Used for: synthesize, taxonomy, gaps, idea_generation, draft, review, revision
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Groq (free tier, fast) ───────────────────────────────────────
# GROQ_API_KEY=your-groq-api-key-here  (not in use)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════
#  Database — PostgreSQL
#  Format: postgresql://user:password@host:5432/dbname
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:abc@localhost:5432/research_platform

# ═══════════════════════════════════════════════════════════════
#  Auth & Security
#  Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════
SECRET_KEY=changeme-replace-with-64-char-random-hex-string
ENCRYPTION_KEY=changeme-replace-with-64-char-random-hex-string

# ═══════════════════════════════════════════════════════════════
#  External APIs (all optional — features degrade gracefully)
# ═══════════════════════════════════════════════════════════════
SEMANTIC_SCHOLAR_API_KEY=tNqf5EoKkKe9
IEEE_API_KEY=your-ieee-api-key-here
GRAMMARLY_CLIENT_ID=
GRAMMARLY_CLIENT_SECRET=
GITHUB_API_TOKEN=your-github-token-here

# ═══════════════════════════════════════════════════════════════
#  App Settings
# ═══════════════════════════════════════════════════════════════
APP_ENV=development
LOG_LEVEL=INFO
MAX_PAPERS_PER_QUERY=20
PDF_DOWNLOAD_DIR=./storage/pdfs
