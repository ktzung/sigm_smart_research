# ═══════════════════════════════════════════════════════════════
#  LLM Provider Selection
#  Set LLM_PROVIDER to one of:
#    openai | perplexity | anthropic | gemini | ollama | minimax | openai_compat
# ═══════════════════════════════════════════════════════════════
LLM_PROVIDER=openai

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # default, no need to set

# ── Perplexity ──────────────────────────────────────────────────
# Perplexity's sonar models have built-in web search - great for discovery
# Get key at: https://www.perplexity.ai/settings/api
# LLM_PROVIDER=perplexity
PERPLEXITY_API_KEY=pplx-your-key
PERPLEXITY_MODEL=sonar-pro
# Other options: sonar | sonar-reasoning | sonar-reasoning-pro

# ── Anthropic Claude ────────────────────────────────────────────
# Get key at: https://console.anthropic.com/
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Other options: claude-opus-4-5 | claude-sonnet-4-5

# ── MiniMax ────────────────────────────────────────────────────
# Get key at: https://platform.minimax.io/subscribe/token-plan
# LLM_PROVIDER=minimax
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimax.io/v1
# If you are in China, use: https://api.minimaxi.com/v1

# ── Google Gemini ───────────────────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza-your-key
GEMINI_MODEL=gemini-2.0-flash
# Other options: gemini-2.5-pro | gemini-2.5-flash

# ── Ollama (local, no API key needed) ───────────────────────────
# Install Ollama: https://ollama.com  then: ollama pull llama3.2
# LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
# Other options: mistral | qwen2.5 | deepseek-r1

# ── OpenAI-compatible (Groq, Together AI, LM Studio, etc.) ──────
# LLM_PROVIDER=openai_compat
# OPENAI_API_KEY=your-groq-or-together-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════════
#  Database
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=sqlite:///./research_platform.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/research_platform

# ── Groq (fast inference, free tier) ────────────────────────────────────────
# Get key at: https://console.groq.com/keys
# LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Other options: llama-4-scout-17b-16e-instruct | deepseek-r1-distill-llama-70b | qwen-qwq-32b
# Get token at: https://github.com/settings/tokens → Generate new token (classic)
# Required scope: public_repo (read-only)
# Used for: awesome-list discovery, code analysis
GITHUB_API_TOKEN=

# ═══════════════════════════════════════════════════════════════
#  App Settings
# ═══════════════════════════════════════════════════════════════
APP_ENV=development
LOG_LEVEL=INFO
MAX_PAPERS_PER_QUERY=20
PDF_DOWNLOAD_DIR=./storage/pdfs
